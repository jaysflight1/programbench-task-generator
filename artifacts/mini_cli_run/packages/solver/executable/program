#!/usr/bin/env python3
from __future__ import annotations

import sys


VERSION = "pbcalc 1.0"


def usage() -> str:
    return """Usage: pbcalc COMMAND [ARGS]

Commands:
  add NUM...     Sum decimal numbers.
  mul NUM...     Multiply decimal numbers.
  stats NUM...   Print count, sum, mean, min, and max.

Options:
  -h, --help     Show help.
  --version      Show version.
"""


def parse_numbers(values: list[str]) -> list[float]:
    if not values:
        raise ValueError("at least one number is required")
    numbers: list[float] = []
    for value in values:
        try:
            numbers.append(float(value))
        except ValueError as exc:
            raise ValueError(f"invalid number: {value}") from exc
    return numbers


def fmt(value: float) -> str:
    if value == int(value):
        return str(int(value))
    return f"{value:.10g}"


def main(argv: list[str]) -> int:
    if not argv or argv[0] in {"-h", "--help"}:
        print(usage(), end="")
        return 0
    if argv[0] == "--version":
        print(VERSION)
        return 0
    command, *rest = argv
    try:
        numbers = parse_numbers(rest)
        if command == "add":
            print(fmt(sum(numbers)))
            return 0
        if command == "mul":
            result = 1.0
            for number in numbers:
                result *= number
            print(fmt(result))
            return 0
        if command == "stats":
            total = sum(numbers)
            print(f"count={len(numbers)}")
            print(f"sum={fmt(total)}")
            print(f"mean={fmt(total / len(numbers))}")
            print(f"min={fmt(min(numbers))}")
            print(f"max={fmt(max(numbers))}")
            return 0
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    print(f"unknown command: {command}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
